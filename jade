                local target = ensureRaidTarget()
                if not target then return end
                local targetHRP = target:FindFirstChild("HumanoidRootPart")
                if not targetHRP then state.raidTarget = nil; return end
                local targetPos  = targetHRP.Position
                local orbitAngle = os.clock() * state.orbitSpeed
                local offsetX    = math.cos(orbitAngle) * state.orbitRadius
                local offsetZ    = math.sin(orbitAngle) * state.orbitRadius
                pcall(function()
                    myHRP.Position = Vector3.new(
                        targetPos.X + offsetX,
                        targetPos.Y,
                        targetPos.Z + offsetZ
                    )
                    myHRP.Velocity    = Vector3.new(0, 0, 0)
                    myHRP.RotVelocity = Vector3.new(0, 0, 0)
                end)
                pcall(lookAtStep)
                pcall(disableCollisions, myChar)
                pcall(mouse1press)
            end)
            task.wait()
        end
        pcall(mouse1release)
    end

