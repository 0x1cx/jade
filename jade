    local function setLockYPosition(forceExact)
        local root = getRootPart()
        if not root then return end
        local pos = root.Position
        if forceExact or pos.Y < config.lockYValue then
            pcall(function() root.Position = Vector3.new(pos.X, config.lockYValue, pos.Z) end)
            pcall(function()
                local vel = root.AssemblyLinearVelocity
                if vel then root.AssemblyLinearVelocity = Vector3.new(vel.X, 0, vel.Z) end
            end)
        end
    end

    local function voidDioLoop()
        while state.voidDio and not state.shouldUnload do
            pcall(function()
                local root = getRootPart()
                if not root then return end
                if not state.lockMotionOrigin then
                    local pos = root.Position
                    state.lockMotionOrigin = Vector3.new(pos.X, config.lockYValue, pos.Z)
                end
                local origin = state.lockMotionOrigin
                local angle = os.clock() * (config.lockMoveSpeed / config.lockMoveRange)
                local offsetX = math.cos(angle) * config.lockMoveRange
                local offsetZ = math.sin(angle) * config.lockMoveRange
                root.Position = Vector3.new(origin.X + offsetX, config.lockYValue, origin.Z + offsetZ)
                local vel = root.AssemblyLinearVelocity
                if vel then root.AssemblyLinearVelocity = Vector3.new(0, 0, 0) end
            end)
            task.wait()
        end
    end

    local function startVoidDio()
