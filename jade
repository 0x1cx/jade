    local standESPDrawings = {}

    local function renderPlayerStandESP()
        if not state.playerStandESP then
            for k, d in pairs(standESPDrawings) do
                d.nameText.Visible = false
                d.distText.Visible = false
            end
            return
        end

        local root = getRootPart()
        local rootPos = root and root.Position
        local liveFolder = workspace:FindFirstChild("Live")
        if not liveFolder then return end

        local seenThisFrame = {}

        for _, p in ipairs(players:GetPlayers()) do
            if p ~= player then
                pcall(function()
                    local charModel = liveFolder:FindFirstChild(p.Name)
                    if not charModel then return end
                    if p.Name == player.Name then return end
                    local val = charModel:GetAttribute("SummonedStand") or ""
                    if type(val) ~= "string" then val = tostring(val) end
                    local hasStand = #val >= 2
                    if not hasStand then val = "No Stand Equipped" end

                    local hrp = charModel:FindFirstChild("HumanoidRootPart")
                        or charModel:FindFirstChild("Head")
                    if not hrp then return end
                    local wpos = hrp.Position + Vector3.new(0, 4, 0)

                    local okW, spos, onScreen = pcall(WorldToScreen, wpos)
                    if not okW or not onScreen or not spos then return end

                    seenThisFrame[p.Name] = true

                    local bundle = standESPDrawings[p.Name]
                    if not bundle then
                        local nameText = Drawing.new("Text")
                        nameText.Center = true; nameText.Outline = true
                        nameText.Font = Drawing.Fonts.SystemBold
                        nameText.Size = 15; nameText.Visible = false; nameText.ZIndex = 5
                        nameText.Color = state.standESPColor

                        local distText = Drawing.new("Text")
                        distText.Center = true; distText.Outline = true
                        distText.Font = Drawing.Fonts.System
                        distText.Size = 12; distText.Visible = false; distText.ZIndex = 5
                        distText.Color = Color3.fromRGB(200, 200, 200)

                        bundle = { nameText = nameText, distText = distText }
                        standESPDrawings[p.Name] = bundle
                    end

                    bundle.nameText.Text = val
                    bundle.nameText.Color = state.standESPColor
                    bundle.nameText.Position = Vector2.new(spos.X, spos.Y)
                    bundle.nameText.Visible = true

                    if rootPos then
                        local d = math.floor(distance3D(hrp.Position, rootPos))
                        bundle.distText.Text = d .. " studs"
                        bundle.distText.Position = Vector2.new(spos.X, spos.Y + 16)
                        bundle.distText.Visible = true
                    else
                        bundle.distText.Visible = false
                    end
                end)
            end
        end

        for name, bundle in pairs(standESPDrawings) do
            if not seenThisFrame[name] then
                bundle.nameText.Visible = false
                bundle.distText.Visible = false
            end
        end
    end

    local function removeAllStandESPDrawings()
        for k, d in pairs(standESPDrawings) do
            d.nameText:Remove(); d.distText:Remove()
            standESPDrawings[k] = nil
        end
    end

    local function updateFrame(deltaTime)
        if state.itemESP or state.autoCollect then
            refreshItemCache()
        end
        renderItemESP()
        renderPlayerStandESP()
    end

    local function safeUpdateFrame(deltaTime)
        local now = os.clock()
        if now < state.runtimeCooldownUntil then return end
        local ok = pcall(updateFrame, deltaTime)
        if ok then
            state.frameErrorCount = math.max(0, state.frameErrorCount - 1)
            return
        end
        state.frameErrorCount = state.frameErrorCount + 1
        if state.frameErrorCount >= 20 then
            state.itemESP          = false
            state.autoCollect      = false
            state.npcKillerEnabled = false
            stopAutoCollect()
            stopAllNpcKillerLoops()
            hideAllItemDrawings()
            state.runtimeCooldownUntil = now + 1.5
            state.frameErrorCount = 0
        end
    end


    local frameLoopAlive = true
    task.spawn(function()
        while frameLoopAlive and not state.shouldUnload do
            safeUpdateFrame(config.fallbackDeltaTime)
            task.wait()
        end
    end)

