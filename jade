                            if centerPos then
                                state.pveTargets = {}
                                local hasTargets = false
                                if liveFolder then
                                    for _, npc in ipairs(liveFolder:GetChildren()) do
                                        if not playerNames[npc.Name] and npc:FindFirstChildWhichIsA("Highlight") and npc:FindFirstChild("Humanoid") and npc.Humanoid.Health > 0 then
                                            local hrp = npc:FindFirstChild("HumanoidRootPart")
                                            if hrp and distance3D(hrp.Position, centerPos) <= 500 then
                                                state.pveTargets[npc] = true
                                                hasTargets = true
                                            end
                                        end
                                    end
                                end
                                
                                if hasTargets then
                                    state.npcKillerEnabled = true
                                    startNpcKillerForCurrentMethod()
                                    pcall(function() npcToggle:SetValue(true) end)
                                    
                                    while state.autoPveQuest and state.npcKillerEnabled do
                                        local stillAlive = false
                                        for npc, _ in pairs(state.pveTargets) do
                                            if npc.Parent and npc:FindFirstChildWhichIsA("Highlight") and npc:FindFirstChild("Humanoid") and npc.Humanoid.Health > 0 then
                                                stillAlive = true
                                                break
                                            end
                                        end
                                        if not stillAlive then break end
                                        task.wait(0.2)
                                    end
                                    
                                    state.pveTargets = nil
                                    state.npcKillerEnabled = false
                                    stopAllNpcKillerLoops()
                                    pcall(function() npcToggle:SetValue(false) end)
                                    
                                    task.wait(1)
                                    break
                                end
                            end
                        end
                    end
                end
                
                task.wait(0.1)
            end
            
            if keyrelease then pcall(keyrelease, 0x45) end
        end
    end

